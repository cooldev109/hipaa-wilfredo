// ============================================
// ALWAYS-INCLUDED — Summary & Recommendations
// ============================================

function summaryDiagnosesBlock(patient, evaluation, lang) {
  const t = L(lang);
  const diagnoses = evaluation.diagnoses || [];
  if (diagnoses.length === 0) return '';

  const list = diagnoses.map((d) => {
    const info = t.diagnoses[d.code] || { name: d.name, desc: '' };
    return `<li><strong>${info.name} (${d.code}):</strong> ${info.desc}</li>`;
  }).join('');

  return `
    <div class="section">
      <h3>${t.summaryHeading}</h3>
      <p>${t.summaryIntro(patient.firstName)}</p>
      <ul>${list}</ul>
      <p>${t.summaryClose(patient.firstName)}</p>
    </div>
  `;
}

function recommendationsBlock(patient, evaluation, lang) {
  const t = L(lang);
  const recs = evaluation.recommendations || [];
  const activeRecs = Array.isArray(recs)
    ? recs.filter((r) => r.included)
    : Object.entries(recs).filter(([, v]) => v).map(([key]) => ({ key, included: true }));

  const recList = activeRecs.length > 0
    ? activeRecs.map((r) => `<li>${t.recLabels[r.key] || r.text || r.key}</li>`).join('')
    : '';

  return `
    <div class="section">
      <h3>${t.recommendationsHeading}</h3>
      ${recList ? `<ul>${recList}</ul>` : ''}
    </div>
  `;
}

function interventionPlanBlock(patient, evaluation, lang) {
  const t = L(lang);
  const items = t.interventionItems.map(([title, desc]) => `<li><strong>${title}</strong> ${desc}</li>`).join('');
